{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ship-cycle project overlay",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "vcs": {
      "type": "object",
      "properties": {
        "provider": { "type": "string" },
        "repo": { "type": "string" },
        "defaultBase": { "type": "string" },
        "protectedBranches": { "type": "array", "items": { "type": "string" } },
        "tracker": {
          "type": "object",
          "properties": {
            "milestones": { "type": "boolean" },
            "projectBoard": { "type": "string" }
          }
        }
      },
      "required": ["defaultBase", "protectedBranches"]
    },
    "changeNature": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "match": {
            "oneOf": [
              { "type": "string" },
              { "type": "array", "items": { "type": "string" } }
            ]
          },
          "nature": { "type": "string" },
          "tests": { "type": "array", "items": { "type": "string" } },
          "build": { "type": "array", "items": { "type": "string" } },
          "reviews": { "type": "array", "items": { "type": "string" } }
        },
        "required": ["match", "nature", "reviews"]
      }
    },
    "i18n": {
      "type": "object",
      "properties": { "configPath": { "type": "string" } }
    },
    "design": {
      "type": "object",
      "properties": {
        "tokens": { "type": "array", "items": { "type": "string" } },
        "components": { "type": "array", "items": { "type": "string" } },
        "guide": { "type": "string" }
      }
    },
    "audit": {
      "type": "object",
      "properties": {
        "sourceOfTruth": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "paths": { "type": "array", "items": { "type": "string" } }
          }
        },
        "surfaces": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "routes": { "type": "array", "items": { "type": "string" } },
              "client": { "type": "array", "items": { "type": "string" } }
            },
            "required": ["name"]
          }
        },
        "modules": { "type": "array", "items": { "type": "string" } },
        "reportDir": { "type": "string" }
      }
    },
    "modelRouting": {
      "type": "object",
      "properties": {
        "tierMap": {
          "type": "object",
          "properties": {
            "top": { "type": "string" },
            "high": { "type": "string" },
            "mid": { "type": "string" },
            "low": { "type": "string" }
          }
        },
        "base": { "type": "object" },
        "securityReviewModel": {
          "type": "string",
          "description": "Model id forced for security/authz reviews, overriding tierMap for that role, so a risk-gated security review can never land on a model that refuses security analysis. PREFLIGHT uses it as the substitute when a resolved model is denied by mustNotUse."
        },
        "mustNotUse": {
          "type": "object",
          "description": "Per-risk-axis denylist of model ids (keys: 'security', 'auth', 'authz', or any risk axis). When PREFLIGHT resolves a role tied to that axis and tierMap yields a denied model, it substitutes securityReviewModel (or the nearest allowed tier) and logs the swap; if no allowed model remains it fails closed (halts).",
          "additionalProperties": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "env": {
      "type": "object",
      "properties": {
        "reuseDevServer": {
          "description": "Reuse an already-running dev server for QA. A bare port number, an object with an explicit health check, or true to auto-detect a running server.",
          "oneOf": [
            { "type": "integer", "description": "Port to health-check and reuse." },
            {
              "type": "object",
              "properties": {
                "port": { "type": "integer" },
                "healthPath": { "type": "string" }
              },
              "required": ["port"]
            },
            { "const": true, "description": "Auto-detect: reuse whatever dev server is already up." }
          ]
        },
        "sharedNodeModules": { "type": "boolean" },
        "reuseE2EInstall": { "type": "boolean" }
      }
    }
  }
}
