{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ship-cycle project overlay",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "vcs": {
      "type": "object",
      "properties": {
        "provider": { "type": "string" },
        "repo": { "type": "string" },
        "defaultBase": { "type": "string" },
        "protectedBranches": { "type": "array", "items": { "type": "string" } },
        "tracker": {
          "type": "object",
          "properties": {
            "milestones": { "type": "boolean" },
            "projectBoard": { "type": "string" }
          }
        }
      },
      "required": ["defaultBase", "protectedBranches"]
    },
    "changeNature": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "match": {
            "oneOf": [
              { "type": "string" },
              { "type": "array", "items": { "type": "string" } }
            ]
          },
          "nature": { "type": "string" },
          "tests": { "type": "array", "items": { "type": "string" } },
          "build": { "type": "array", "items": { "type": "string" } },
          "reviews": { "type": "array", "items": { "type": "string" } }
        },
        "required": ["match", "nature", "reviews"]
      }
    },
    "i18n": {
      "type": "object",
      "properties": { "configPath": { "type": "string" } }
    },
    "design": {
      "type": "object",
      "properties": {
        "tokens": { "type": "array", "items": { "type": "string" } },
        "components": { "type": "array", "items": { "type": "string" } },
        "guide": { "type": "string" }
      }
    },
    "audit": {
      "type": "object",
      "properties": {
        "sourceOfTruth": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "paths": { "type": "array", "items": { "type": "string" } }
          }
        },
        "surfaces": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "routes": { "type": "array", "items": { "type": "string" } },
              "client": { "type": "array", "items": { "type": "string" } }
            },
            "required": ["name"]
          }
        },
        "modules": { "type": "array", "items": { "type": "string" } },
        "reportDir": { "type": "string" }
      }
    },
    "modelRouting": {
      "type": "object",
      "properties": {
        "tierMap": {
          "type": "object",
          "properties": {
            "top": { "type": "string" },
            "high": { "type": "string" },
            "mid": { "type": "string" },
            "low": { "type": "string" }
          }
        },
        "base": { "type": "object" },
        "securityReviewModel": {
          "type": "string",
          "description": "Model id the 'security' and 'authz' review lenses MUST use, overriding their tier-resolved model. Set it when your top/high tier resolves to a model that refuses security analysis — such a review silently no-ops. Pin the most capable model that WILL do security review, at your HIGHEST security-review tier — note auth/payment risk upgrades that lens to 'top', and the pin overrides that upgrade too. Enforced when sc-review spawns those lenses; PREFLIGHT records it as models['review.security'] and logs SC-ROUTE-AVOID when the pin differs from the tier-resolved model. Opt-in: absent, the security lens uses its tier model."
        }
      }
    },
    "env": {
      "type": "object",
      "properties": {
        "reuseDevServer": {
          "description": "Reuse an already-running dev server for QA. A bare port number, an object with an explicit health check, or true to auto-detect a running server.",
          "oneOf": [
            { "type": "integer", "description": "Port to health-check and reuse." },
            {
              "type": "object",
              "properties": {
                "port": { "type": "integer" },
                "healthPath": { "type": "string" }
              },
              "required": ["port"]
            },
            { "const": true, "description": "Auto-detect: reuse whatever dev server is already up." }
          ]
        },
        "sharedNodeModules": { "type": "boolean" },
        "reuseE2EInstall": { "type": "boolean" }
      }
    }
  }
}
